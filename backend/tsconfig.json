{
  "compilerOptions": {
    /* Target modern JavaScript */
    "target": "ES2022",

    /* Use Node.js module system */
    "module": "NodeNext",

    /* Resolve imports like Node.js */
    "moduleResolution": "NodeNext",

    /* Source code location */
    "rootDir": "./src",

    /* Build output location */
    "outDir": "./dist",

    /* Enable strict type checking */
    "strict": true,

    /* Allow importing Express properly */
    "esModuleInterop": true,

    /* Skip checking library declaration files */
    "skipLibCheck": true,

    /* Keep filename casing consistent */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"]
}